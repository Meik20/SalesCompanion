# ────────────────────────────────────────────────────────
# Firestore (Primary Database)
# ────────────────────────────────────────────────────────

# Path to your Firebase service account key JSON file
# Generate from: https://console.firebase.google.com → Settings → Service Accounts
# 
# Option 1: Absolute path to local file (development)
#   GOOGLE_APPLICATION_CREDENTIALS=/path/to/serviceAccountKey.json
#
# Option 2: Set as environment variable on Railway/Heroku with full JSON content
#   (Recommended for production)
#
GOOGLE_APPLICATION_CREDENTIALS=/absolute/path/to/serviceAccountKey.json

# Enable or disable Firestore (default: true)
FIRESTORE_SYNC_ENABLED=true

# ────────────────────────────────────────────────────────
# Firebase Web Config (for frontend applications)
# ────────────────────────────────────────────────────────

# Firebase project credentials (for SPA/Mobile)
# From: Firebase Console → Settings → Project Settings → Web App
FIREBASE_APIKEY=AIzaSyCVJxyeysHWDQ7yECTb-GApJz7u8s5l7N0
FIREBASE_AUTHDOMAIN=sales-companion-9cf56.firebaseapp.com
FIREBASE_PROJECTID=sales-companion-9cf56
FIREBASE_STORAGEBUCKET=sales-companion-9cf56.firebasestorage.app
FIREBASE_MESSAGINGSENDERID=1058275289756
FIREBASE_APPID=1:1058275289756:web:534cd79d5eb373348f5b59

# ────────────────────────────────────────────────────────
# Application Settings
# ────────────────────────────────────────────────────────

# Server port (default: 3311)
PORT=3311

# JWT secret for token signing (change in production!)
# Should be long and random: generate with: openssl rand -hex 32
JWT_SECRET=sc-secret-2025-change-me-in-production

# Node environment (development/production)
NODE_ENV=development

# Server IP for network discovery
# Leave empty for auto-detection or set explicit IP
SERVER_IP=

# ────────────────────────────────────────────────────────
# AI & Third-party Services
# ────────────────────────────────────────────────────────

# GROQ API key for AI chat feature
# Get free API key: https://console.groq.com/keys
# Format: gsk_...
GROQ_API_KEY=

# ────────────────────────────────────────────────────────
# SETUP INSTRUCTIONS
# ────────────────────────────────────────────────────────

# 1. Firestore Setup (REQUIRED):
#    a) Create project: https://console.firebase.google.com
#    b) Settings → Service Accounts → Generate Private Key
#    c) Download JSON and set GOOGLE_APPLICATION_CREDENTIALS
#    d) Create Firestore Database (Settings → Firestore)
#    e) Apply security rules from server/FIRESTORE-SETUP.md
#
# 2. Start server:
#    cd server && npm install && npm start
#
# See documentation:
#    - FIRESTORE-QUICKSTART.md (Firestore quick start)
#    - server/FIRESTORE-SETUP.md (Complete Firestore setup)
